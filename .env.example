# Qdrant Cloud bağlantı bilgileri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env'yi git'e KOMMITLEMEYIN (.gitignore'da olmalı).

QDRANT_URL=https://your-cluster-url
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=kap_bist30

# KAP tarih aralığı. Boş bırakılırsa son 90 gün kullanılır.
KAP_START_DATE=
KAP_END_DATE=
KAP_LOOKBACK_DAYS=90

# KAP web indirme. MKK API key/secret kullanılmaz.
KAP_BASE_URL=https://www.kap.org.tr
KAP_LANGUAGE=tr
KAP_DOWNLOAD_EXTENSIONS=.pdf
KAP_REQUEST_DELAY_SEC=1.0
KAP_DOWNLOAD_TIMEOUT_SEC=60.0
KAP_MAX_RETRIES=4
KAP_RETRY_BACKOFF_SEC=2.0
